---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import Process from '../components/Process.astro';
import About from '../components/About.astro';
import Legislation from '../components/Legislation.astro';
import Targets from '../components/Targets.astro';
import Contact from '../components/Contact.astro';
import Stats from '../components/Stats.astro';
import Pricing from '../components/Pricing.astro';
import Blog from '../components/Blog.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "name": "Kontrola systému vytápění - Ing. Petr Novák",
      "image": "https://kontrola-systemu-vytapeni.cz/assets/images/hero-bg.webp",
      "@id": "https://kontrola-systemu-vytapeni.cz",
      "url": "https://kontrola-systemu-vytapeni.cz",
      "telephone": "+420722605230",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Weighartova 362/9",
        "addressLocality": "Brno",
        "postalCode": "621 00",
        "addressCountry": "CZ"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 49.255,
        "longitude": 16.591
      },
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": [
          "Monday",
          "Tuesday",
          "Wednesday",
          "Thursday",
          "Friday"
        ],
        "opens": "08:00",
        "closes": "17:00"
      },
      "areaServed": [
        {
          "@type": "City",
          "name": "Brno"
        },
        {
          "@type": "City",
          "name": "Praha"
        },
        {
          "@type": "City",
          "name": "Ostrava"
        },
        {
          "@type": "Country",
          "name": "Česká republika"
        }
      ],
      "description": "Profesionální kontrola systému vytápění dle vyhlášky 38/2022 Sb. prováděná certifikovaným energetickým specialistou pro SVJ, firmy a veřejnou správu."
    }
  ]
};

const metaTitle = "Kontrola systému vytápění dle vyhlášky 38/2022 Sb. | Celá ČR";
const metaDescription = "Odborná kontrola systému vytápění dle vyhlášky 38/2022 Sb. pro SVJ, firmy a veřejné budovy. Zajištění legislativní shody a optimalizace provozních nákladů po celé ČR.";
---

<Layout title={metaTitle} description={metaDescription} structuredData={structuredData}>
    <Navigation />
    <main>
        <Hero />
        <Features />
        <Process />
        <About />
        <Legislation />
        <Targets />
        <Contact />
        <Stats />
        <Pricing />
        <Blog />
        <FAQ />
    </main>
    <Footer />
</Layout>
