                            <span class="text-2xl font-bold text-on-surface-variant">Kč</span>
                        </div>
                        <p class="text-sm font-medium text-slate-400 mt-2">bez DPH</p>
                    </div>
                    <div class="w-full space-y-6 mb-12">
                        <div class="flex items-start gap-4">
                            <div class="bg-emerald-50 p-1.5 rounded-full text-primary">
                                <span class="material-symbols-outlined text-xl font-bold">check_circle</span>
                            </div>
                            <div>
                                <p class="font-bold text-on-surface">Kontrola energetickým specialistou</p>
