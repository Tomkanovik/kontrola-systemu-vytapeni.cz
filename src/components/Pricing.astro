<section class="py-24 bg-background" id="pricing">
    <div class="max-w-7xl mx-auto px-8">
        <div class="text-center mb-16">
            <h2 class="font-headline text-4xl font-extrabold mb-4">Kolik stojí kontrola systému vytápění</h2>
            <div class="h-1.5 w-24 bg-primary rounded-full mx-auto"></div>
