---
const faqs = [
    {
        question: "Je kontrola opravdu povinná?",
        answer: "Ano, zákonná povinnost vyplývá přímo ze <strong>zákona č. 406/2000 Sb.</strong> o hospodaření energií, který ukládá vlastníkům budov s instalovaným jmenovitým výkonem nad 70 kW zajistit pravidelnou kontrolu. Podrobnosti o formě a technických parametrech této kontroly pak stanovuje prováděcí <strong>vyhláška č. 38/2022 Sb.</strong>"
    },
    {
        question: "Jaké jsou důsledky chybějící kontroly?",
        answer: "Nepředložení platného protokolu při inspekci prováděné Státní energetickou inspekcí (SEI) je posuzováno jako porušení zákonné povinnosti, za které může být právnické osobě uložena pokuta až <strong>200 000 Kč</strong>. Absence odborné kontroly může být rovněž problematická při řešení pojistných událostí v kotelně."
    },
    {
        question: "Jak dlouho platí výsledek kontroly?",
        answer: "Platnost protokolu o kontrole systému vytápění je standardně <strong>5 let</strong>. U nově instalovaných systémů musí být první kontrola provedena nejpozději do 3 let od uvedení do provozu."
    },
    {
        question: "Kdo může tuto kontrolu legálně provádět?",
        answer: "Kontrolu smí provádět výhradně <strong>energetický specialista</strong> zapsaný v seznamu vedeném Ministerstvem průmyslu a obchodu, který má konkrétní oprávnění pro kontrolu systémů vytápění. Běžný servisní technik kotle tento protokol vystavit nemůže."
    },
    {
        question: "Týká se kontrola i rodinných domů?",
        answer: "Většinou ne. Limit 70 kW je nastaven tak, aby běžné rodinné domy (které mají obvykle kotel s výkonem 15-30 kW) do této povinnosti nespadaly. Výjimkou jsou velmi rozlehlé rezidence s více zdroji tepla."
    },
    {
        question: "Platí povinnost i pro tepelná čerpadla?",
        answer: "Ano, vyhláška se vztahuje na všechny systémy vytápění bez ohledu na palivo, pokud přesahují výkon 70 kW. Týká se tedy i tepelných čerpadel, elektrokotlů i výměníkových stanic."
    },
    {
        question: "Působíte i v menších městech?",
        answer: "Samozřejmě. I když máme silné zázemí v Brně, Praze a Ostravě, naši specialisté cestují za klienty po celém území České republiky."
    }
];

const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(faq => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": {
            "@type": "Answer",
            "text": faq.answer.replace(/<\/?[^>]+(>|$)/g, "")
        }
    }))
};
---

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<section class="py-24 bg-surface-container-low" id="faq">
    <div class="max-w-3xl mx-auto px-8">
        <h2 class="font-headline text-4xl font-extrabold mb-12 text-center">Časté otázky</h2>
        <div class="space-y-4">
            {faqs.map((faq) => (
                <div class="faq-item bg-white rounded-2xl p-6 shadow-sm overflow-hidden">
                    <button class="w-full flex justify-between items-center text-left font-bold text-lg group cursor-pointer focus:outline-none">
                        <span>{faq.question}</span>
                        <span class="material-symbols-outlined text-primary transition-transform duration-300">expand_more</span>
                    </button>
                    <div class="faq-content mt-0 max-h-0 opacity-0 transition-all duration-300 ease-in-out">
                        <div class="pt-4 text-on-surface-variant leading-relaxed" set:html={faq.answer} />
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<script>
    import "../scripts/faq.ts";
</script>
