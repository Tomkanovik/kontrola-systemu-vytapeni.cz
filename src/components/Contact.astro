---
---

<section class="py-24 bg-white" id="contact">
    <div class="max-w-7xl mx-auto px-8 grid md:grid-cols-2 gap-20">
        <div>
            <h2 class="font-headline text-4xl font-extrabold mb-6">Zajistěte si termín kontroly</h2>
            <p class="text-lg text-on-surface-variant mb-12 leading-relaxed">Splňte povinnost včas a začněte šetřit na provozních nákladech. Ozveme se vám do 24 hodin s konkrétním návrhem termínu a kalkulací.</p>
            <div class="space-y-8">
                <div class="flex gap-6">
                    <div class="w-12 h-12 flex-shrink-0 bg-surface-container rounded-xl flex items-center justify-center text-primary">
                        <span class="material-symbols-outlined">person</span>
                    </div>
                    <div>
                        <p class="text-sm text-slate-500 font-bold uppercase tracking-wider">Energetický specialista</p>
                        <a href="https://prukaz.info/kontakty/petr-novak/" class="text-xl font-bold hover:text-primary transition-colors" target="_blank" rel="noopener noreferrer">Ing. Petr Novák</a>
                    </div>
                </div>
                <div class="flex gap-6">
                    <div class="w-12 h-12 flex-shrink-0 bg-surface-container rounded-xl flex items-center justify-center text-primary">
                        <span class="material-symbols-outlined">phone_in_talk</span>
                    </div>
                    <div>
                        <p class="text-sm text-slate-500 font-bold uppercase tracking-wider">Telefon</p>
                        <a href="tel:+420722605230" class="text-xl font-bold hover:text-primary transition-colors">+420 722 605 230</a>
                    </div>
                </div>
                <div class="flex gap-6">
                    <div class="w-12 h-12 flex-shrink-0 bg-surface-container rounded-xl flex items-center justify-center text-primary">
                        <span class="material-symbols-outlined">mail</span>
                    </div>
                    <div>
                        <p class="text-sm text-slate-500 font-bold uppercase tracking-wider">Email</p>
                        <a href="mailto:info@kontrola-systemu-vytapeni.cz" class="text-xl font-bold hover:text-primary transition-colors">info@kontrola-systemu-vytapeni.cz</a>
                    </div>
                </div>
            </div>
        </div>
        <form class="bg-surface-container-low p-10 rounded-3xl space-y-6 shadow-sm border border-emerald-50">
            <h3 class="text-2xl font-bold mb-4">Nezávazná poptávka</h3>
            <div class="grid grid-cols-2 gap-4">
                <div class="col-span-2">
                    <label class="block text-sm font-bold mb-2" for="object-type">Typ objektu *</label>
                    <select id="object-type" class="w-full bg-surface-container-lowest border-none rounded-xl p-4 focus:ring-2 focus:ring-primary/40 transition-all" required>
                        <option value="">Vyberte typ objektu</option>
                        <option>Bytový dům / SVJ</option>
                        <option>Administrativní budova</option>
                        <option>Průmyslový areál</option>
                        <option>Veřejná budova</option>
                        <option>Jiný</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-bold mb-2" for="power">Příkon (kW) *</label>
                    <input id="power" class="w-full bg-surface-container-lowest border-none rounded-xl p-4 focus:ring-2 focus:ring-primary/40 transition-all" placeholder="např. 150" type="number" min="70" required/>
                </div>
                <div>
                    <label class="block text-sm font-bold mb-2" for="location">Lokalita *</label>
                    <input id="location" class="w-full bg-surface-container-lowest border-none rounded-xl p-4 focus:ring-2 focus:ring-primary/40 transition-all" placeholder="Město" type="text" required/>
                </div>
                <div class="col-span-2">
                    <label class="block text-sm font-bold mb-2" for="name">Jméno a příjmení *</label>
                    <input id="name" class="w-full bg-surface-container-lowest border-none rounded-xl p-4 focus:ring-2 focus:ring-primary/40 transition-all" placeholder="Jan Novák" type="text" required/>
                </div>
                <div class="col-span-2">
                    <label class="block text-sm font-bold mb-2" for="email">E-mail *</label>
                    <input id="email" class="w-full bg-surface-container-lowest border-none rounded-xl p-4 focus:ring-2 focus:ring-primary/40 transition-all" placeholder="vas@email.cz" type="email" required/>
                </div>
                <div class="col-span-2">
                    <label class="block text-sm font-bold mb-2" for="phone">Telefon</label>
                    <input id="phone" class="w-full bg-surface-container-lowest border-none rounded-xl p-4 focus:ring-2 focus:ring-primary/40 transition-all" placeholder="+420..." type="tel"/>
                </div>
            </div>
            <button class="w-full primary-gradient text-white font-bold py-4 rounded-xl hover:scale-[1.02] transition-transform text-lg shadow-lg" type="submit">
                Odeslat poptávku kontroly
            </button>
            <p class="text-xs text-on-surface-variant text-center">Odesláním formuláře souhlasíte se zpracováním osobních údajů.</p>
        </form>
    </div>
</section>
