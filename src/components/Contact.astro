---
---

<section class="py-24 bg-white" id="contact">
    <div class="max-w-7xl mx-auto px-8 grid md:grid-cols-2 gap-20">
        <div>
            <h2 class="font-headline text-4xl font-extrabold mb-6">Zajistěte si termín kontroly</h2>
            <p class="text-lg text-on-surface-variant mb-12 leading-relaxed">Splňte povinnost včas a začněte šetřit na provozních nákladech. Ozveme se vám do 24&nbsp;hodin s konkrétním návrhem termínu a kalkulací.</p>
            <div class="space-y-8">
                <div class="flex gap-6">
                    <div class="w-12 h-12 flex-shrink-0 bg-surface-container rounded-xl flex items-center justify-center text-primary">
                        <span class="material-symbols-outlined">person</span>
                    </div>
                    <div>
                        <p class="text-sm text-slate-500 font-bold uppercase tracking-wider">Energetický specialista</p>
                        <a href="https://www.prukaz.info/" class="text-xl font-bold text-error hover:opacity-80 transition-opacity block" target="_blank" rel="noopener noreferrer">Ing. Petr Novák</a>
                        <p class="text-sm text-slate-500 font-medium">IČO: 48873314</p>
                    </div>
                </div>
                <div class="flex gap-6">
                    <div class="w-12 h-12 flex-shrink-0 bg-surface-container rounded-xl flex items-center justify-center text-primary">
                        <span class="material-symbols-outlined">phone_in_talk</span>
                    </div>
                    <div>
                        <p class="text-sm text-slate-500 font-bold uppercase tracking-wider">Telefon</p>
                        <a href="tel:+420722605230" class="text-xl font-bold hover:text-primary transition-colors">+420 722 605 230</a>
                    </div>
                </div>
                <div class="flex gap-6">
                    <div class="w-12 h-12 flex-shrink-0 bg-surface-container rounded-xl flex items-center justify-center text-primary">
                        <span class="material-symbols-outlined">mail</span>
                    </div>
                    <div>
                        <p class="text-sm text-slate-500 font-bold uppercase tracking-wider">Email</p>
                        <a href="mailto:info@kontrola-systemu-vytapeni.cz" class="text-xl font-bold hover:text-primary transition-colors">info@kontrola-systemu-vytapeni.cz</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="bg-surface-container-low p-10 rounded-3xl shadow-sm border border-emerald-50 relative">
            <form id="contact-form" class="space-y-6" action="/api/contact" method="POST">
                <h3 class="text-2xl font-bold mb-4">Nezávazná poptávka</h3>
                <div class="grid grid-cols-2 gap-4">
                    <!-- Honeypot -->
                    <div class="hidden" aria-hidden="true">
                        <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" />
                    </div>

                    <div class="col-span-2">
                        <label class="block text-sm font-bold mb-2" for="object-type">Typ objektu *</label>
                        <select id="object-type" name="object-type" class="w-full bg-surface-container-lowest border-none rounded-xl p-4 focus:ring-2 focus:ring-primary/40 transition-all" required>
                            <option value="">Vyberte typ objektu</option>
                            <option>Bytový dům / SVJ</option>
                            <option>Administrativní budova</option>
                            <option>Průmyslový areál</option>
                            <option>Veřejná budova</option>
                            <option>Jiný</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-bold mb-2" for="power">Příkon (kW) *</label>
                        <input id="power" name="power" class="w-full bg-surface-container-lowest border-none rounded-xl p-4 focus:ring-2 focus:ring-primary/40 transition-all" placeholder="např. 150" type="number" required/>
                    </div>
                    <div>
                        <label class="block text-sm font-bold mb-2" for="location">Lokalita (Město) *</label>
                        <input id="location" name="location" class="w-full bg-surface-container-lowest border-none rounded-xl p-4 focus:ring-2 focus:ring-primary/40 transition-all" placeholder="Město" type="text" required/>
                    </div>
                    <div class="col-span-2">
                        <label class="block text-sm font-bold mb-2" for="name">Jméno a příjmení *</label>
                        <input id="name" name="name" class="w-full bg-surface-container-lowest border-none rounded-xl p-4 focus:ring-2 focus:ring-primary/40 transition-all" placeholder="Jan Novák" type="text" required/>
                    </div>
                    <div class="col-span-2">
                        <label class="block text-sm font-bold mb-2" for="email">E-mail *</label>
                        <input id="email" name="email" class="w-full bg-surface-container-lowest border-none rounded-xl p-4 focus:ring-2 focus:ring-primary/40 transition-all" placeholder="vas@email.cz" type="email" required/>
                    </div>
                    <div class="col-span-2">
                        <label class="block text-sm font-bold mb-2" for="phone">Telefon</label>
                        <input id="phone" name="phone" class="w-full bg-surface-container-lowest border-none rounded-xl p-4 focus:ring-2 focus:ring-primary/40 transition-all" placeholder="+420..." type="tel"/>
                    </div>
                </div>
                <button id="submit-button" class="w-full primary-gradient text-white font-bold py-4 rounded-xl hover:scale-[1.02] transition-transform text-lg shadow-lg disabled:opacity-50 disabled:cursor-not-allowed" type="submit">
                    <span id="button-text">Odeslat poptávku kontroly</span>
                    <span id="button-loader" class="hidden">Odesílám...</span>
                </button>
                <p id="form-error" class="text-error text-sm font-bold text-center hidden"></p>
                <p class="text-xs text-on-surface-variant text-center">Odesláním formuláře souhlasíte se zpracováním osobních údajů.</p>
            </form>

            <!-- Success Message -->
            <div id="success-message" class="hidden absolute inset-0 bg-surface-container-low rounded-3xl flex flex-col items-center justify-center text-center p-10 space-y-4">
                <div class="w-20 h-20 bg-primary/10 rounded-full flex items-center justify-center text-primary mb-4">
                    <span class="material-symbols-outlined text-5xl">check_circle</span>
                </div>
                <h3 class="text-2xl font-bold">Poptávka byla odeslána!</h3>
                <p class="text-on-surface-variant">Děkujeme za váš zájem. Ozveme se vám do 24&nbsp;hodin s konkrétním návrhem termínu.</p>
                <button onclick="document.getElementById('success-message').classList.add('hidden'); const form = document.getElementById('contact-form'); form.style.opacity = '1'; form.style.pointerEvents = 'auto';" class="text-primary font-bold hover:underline">Odeslat další poptávku</button>
            </div>
        </div>
    </div>
</section>

<script>
    import "../scripts/contact.ts";
</script>
